{
  "niri/workspaces#numbers": {
	"active-only": false,
	"all-outputs": true,
	"format": "{icon}",
	"show-special": false,
	"on-click": "activate",
    "persistent-workspaces": {
      "*": 5
	  }
  },
  "niri/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },
  "tray": {
    "icon-size": 18,
    "spacing": 5
  },
  "clock": {
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
	      "months": "<span color='#bb9af7'><b>{}</b></span>",
	      "days": "<span color='#7aa2f7'><b>{}</b></span>", 
	      "weeks": "<span color='#9ece6a'><b>W{}</b></span>", 
	      "weekdays": "<span color='#e0af68'><b>{}</b></span>",
	      "today": "<span background='#2ac3de' color='#1a1b26'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tz_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    },
    "format": "{:%a %d %b | %I:%M %p}",
    "format-alt": "  {:%Y-%m-%d  %H:%M:%S}",
    "interval": 1
  },
  "custom/system": {
    "exec": "bash -c 'echo \"$(uname -s) $(uname -r) @ $(uname -n)\"'",
    "format": "",
    "tooltip-format": " <b>内核信息</b>\n────────────\n{}",
    "on-click": "fuzzel"
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Performance mode:{profile}",
    "tooltip": true,
    "format-icons": {
      "performance": "󱐋",
      "balanced": "",
      "power-saver": ""
    }
  },
  "cpu": {
    "interval": 10,
    "format": "󰍛 {usage}%",
    "rotate": 0,
    "format-alt": "{icon0}{icon1}{icon2}{icon3}",
    "format-icons": ["▁", "▂", "▃", "▄", "▅", "▆", "▇", "█"]
  },
  "memory": {
    "states": {
      "c": 90,
      "h": 60,
      "m": 30
    },
    "interval": 30,
    "format": "\udb83\udf86 {used}GB",
    "rotate": 0,
    "format-m": "\udb83\udf85 {used}GB",
    "format-h": "\udb81\udcc5 {used}GB",
    "format-c": "\uf421 {used}GB",
    "format-alt": "\udb83\udf86 {percentage}%",
    "max-length": 10,
    "tooltip": true,
    "tooltip-format": "\udb83\udf86 Memory usage: {percentage}%\n\ue266 Used: {used:0.2f}GB / {total:0.2f}GB\n\uf472 Available: {avail:0.2f}GB\n\uf233 Swap used: {swapUsed:0.2f}GB / {swapTotal:0.2f}GB ({swapPercentage}%)"
  },
  "temperature": {
    "thermal-zone": 4,
    "critical-threshold": 80,
    "format": " {temperatureC}°C"
  },
  "network": {
    "format": "⚠ Disabled",
    "format-wifi": " {essid}",
    "format-ethernet": "  Wired",
    "format-disconnected": "⚠ Disconnected",
    "format-alt": "{ifname}:{ipaddr}",
    "tooltip-format": "{ifname}:{signalStrength}%",
    "tooltip-format-wifi": "  {essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "  {ifname} ({ipaddr}/{cidr})",
    "tooltip-format-disconnected": "⚠ Disconnected", 
    "on-click-right": "kitty -e nmtui"
  },
  "bluetooth": {
    "format": "󰂯 {status} ",
    "format-disabled": "󰂲",
    "format-off": "󰂲",
    "format-on": "󰂯",
    "format-connected": "󰂱 {device_alias}",
    "tooltip-format": "控制器地址:{controller_address}\n设备连接数:{num_connections}\n{device_enumerate}",
    "on-click": "kitty --class bluetui -e bluetui"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": " {format_source}",
    "format-bluetooth": "󰂰 {volume}%",
    "format-source": " {volume}%",
    "format-source-muted": "",
    "rotate": 0,
    "on-click": "kitty -e ncpamixer",
    "tooltip-format": "{icon} {desc} // {volume}%",
    "scroll-step": 2,
    "format-icons": {
      "usb": "",
      "speakers": "󰓃",
      "headphone": "",
      "phone": "",
      "phone-muted": "",
      "default": ["", "", ""]
    }
  },
  "backlight": {
    "tooltip":false, 
    "states": {
        "Bright": 50
    },
    "device": "intel_backlight",
    "format": "{icon} {percent}%",
    "format-icons": ["", ""]
  },
  "battery": {
    "bat": "BAT0",
    "tooltip": false,
    "interval": 60,
    "states": {
        "warning": 30,
        "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-icons": {
        "default": ["󰂎", "󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
        "charging": ["󰢟", "󰢜", "󰂆", "󰂇", "󰂈", "󰢝", "󰂉", "󰢞", "󰂊", "󰂋", "󰂅"]
    }
  },
  "group/powermenu": {
    "orientation": "inherit",
    "drawer": {
        "transition-duration": 300,
        "children-class": "not-memory",
        "transition-left-to-right": false
    },
    "modules": [
      "custom/shutdown",
      "custom/reboot",
      "custom/logout",
      "custom/hibernate"
    ]
  },
  "custom/shutdown": {
    "tooltip": false,
    "format": "󰐥",
    "on-click": "shutdown now"
  },
  "custom/reboot": {
    "tooltip": false,
    "format": "",
    "on-click": "systemctl reboot"
  },
  "custom/logout": {
    "tooltip": false,
    "format": "󰈆",
    "on-click": "niri msg action quit"
  },
  "custom/hibernate": {
    "tooltip": false,
    "format": "",
    "on-click": "systemctl hibernate"
  },
  "custom/clipboard": {
    "format": "󰅌",
    "tooltip": false,
    "on-click": "cliphist list | fuzzel -d | cliphist decode | wl-copy"
  }
}