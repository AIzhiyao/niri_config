{
  "niri/workspaces#numbers": {
	"active-only": false,
	"all-outputs": true,
	"format": "{icon}",
	"show-special": false,
	"on-click": "activate",
    "persistent-workspaces": {
      "*": 5
	  }
  },
  "niri/mode": {
    "format": "<span style=\"italic\">{}</span>"
  },
  "tray": {
    "icon-size": 18,
    "spacing": 5
  },
  "clock": {
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
	      "months": "<span color='#bb9af7'><b>{}</b></span>",
	      "days": "<span color='#7aa2f7'><b>{}</b></span>", 
	      "weeks": "<span color='#9ece6a'><b>W{}</b></span>", 
	      "weekdays": "<span color='#e0af68'><b>{}</b></span>",
	      "today": "<span background='#2ac3de' color='#1a1b26'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    },
    "format": "{:%a %d %b | %I:%M %p}",
    "format-alt": "п„і  {:%Y-%m-%d пҖ— %H:%M:%S}",
    "interval": 1
  },
  "custom/system": {
    "exec": "bash -c 'echo \"$(uname -s) $(uname -r) @ $(uname -n)\"'",
    "format": "пҢғ",
    "tooltip-format": "п…ј <b>еҶ…ж ёдҝЎжҒҜ</b>\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\n{}",
    "on-click": "fuzzel"
  },
  "cpu": {
    "interval": 10,
    "format": "у°Қӣ {usage}%",
    "rotate": 0,
    "format-alt": "{icon0}{icon1}{icon2}{icon3}",
    "format-icons": ["в–Ғ", "в–Ӯ", "в–ғ", "в–„", "в–…", "в–Ҷ", "в–Ү", "в–Ҳ"]
  },
  "memory": {
    "interval": 30,
    "format": "пғү {used}GB",
    "rotate": 0,
    "format-alt": "пғү {percentage}%",
    "max-length": 10,
    "tooltip": true,
    "tooltip-format": "пғү Memory usage: {percentage}%\n\ue266 Used: {used:0.2f}GB / {total:0.2f}GB\n\uf472 Available: {avail:0.2f}GB\n\uf233 Swap used: {swapUsed:0.2f}GB / {swapTotal:0.2f}GB ({swapPercentage}%)"
  },
  "temperature": {
    "thermal-zone": 4,
    "critical-threshold": 80,
    "format": "пӢү {temperatureC}В°C"
  },
  "network": {
    "format": "вҡ  Disabled",
    "format-wifi": "пҮ« {essid}",
    "format-ethernet": "пғҒ  Wired",
    "format-disconnected": "вҡ  Disconnected",
    "format-alt": "{ifname}:{ipaddr}",
    "tooltip-format": "{ifname}:{signalStrength}%",
    "tooltip-format-wifi": "пҮ«  {essid} ({signalStrength}%)",
    "tooltip-format-ethernet": "пғҒ  {ifname} ({ipaddr}/{cidr})",
    "tooltip-format-disconnected": "вҡ  Disconnected", 
    "on-click-right": "kitty -e nmtui"
  },
  "bluetooth": {
    "format": "у°ӮҜ {status} ",
    "format-disabled": "у°ӮІ",
    "format-off": "у°ӮІ",
    "format-on": "у°ӮҜ",
    "format-connected": "у°Ӯұ {device_alias}",
    "tooltip-format": "жҺ§еҲ¶еҷЁең°еқҖ:{controller_address}\nи®ҫеӨҮиҝһжҺҘж•°:{num_connections}\n{device_enumerate}",
    "on-click": "kitty --class bluetui -e bluetui"
  },
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "о»Ё ",
    "format-bluetooth": "у°Ӯ° {volume}%",
    "format-source": "п„° {volume}%",
    "format-source-muted": "п„ұ",
    "rotate": 0,
    "on-click": "kitty -e ncpamixer",
    "tooltip-format": "{icon} {desc} // {volume}%",
    "scroll-step": 2,
    "format-icons": {
      "usb": "пҖҘ",
      "speakers": "у°“ғ",
      "headphone": "пҖҘ",
      "phone": "пӮ•",
      "phone-muted": "оҙ—",
      "default": ["пҖҰ", "пҖ§", "пҖЁ"]
    }
  },
  "backlight": {
    "tooltip":false, 
    "states": {
        "Bright": 50
    },
    "device": "intel_backlight",
    "format": "{icon} {percent}%",
    "format-icons": ["пҶ…", "п„‘"]
  },
  "battery": {
    "bat": "BAT0",
    "tooltip": false,
    "interval": 60,
    "states": {
        "warning": 30,
        "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-icons": {
        "default": ["у°ӮҺ", "у°Ғә", "у°Ғ»", "у°Ғј", "у°ҒҪ", "у°Ғҫ", "у°Ғҝ", "у°ӮҖ", "у°ӮҒ", "у°ӮӮ", "у°Ғ№"],
        "charging": ["у°ўҹ", "у°ўң", "у°ӮҶ", "у°ӮҮ", "у°ӮҲ", "у°ўқ", "у°Ӯү", "у°ўһ", "у°ӮҠ", "у°ӮӢ", "у°Ӯ…"]
    }
  },
  "group/powermenu": {
    "orientation": "inherit",
    "drawer": {
        "transition-duration": 300,
        "children-class": "not-memory",
        "transition-left-to-right": false
    },
    "modules": [
      "custom/shutdown",
      "custom/reboot",
      "custom/logout",
      "custom/suspend"
    ]
  },
  "custom/shutdown": {
    "tooltip": false,
    "format": "у°җҘ",
    "on-click": "shutdown now"
  },
  "custom/reboot": {
    "tooltip": false,
    "format": "о¬·",
    "on-click": "systemctl reboot"
  },
  "custom/logout": {
    "tooltip": false,
    "format": "у°ҲҶ",
    "on-click": "niri msg action quit"
  },
  "custom/suspend": {
    "tooltip": false,
    "format": "у°Ө„",
    "on-click": "systemctl suspend"
  },
  "custom/clipboard": {
    "format": "у°…Ң",
    "tooltip": false,
    "on-click": "cliphist list | fuzzel -d | cliphist decode | wl-copy"
  }
}